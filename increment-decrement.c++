#include <iostream>
using namespace std;

int main(){
    // disini kita belajar tentang increment dan decrement
    // increment (penjumalahan)
    // decrement (pengurangan)

    // increment ada 2
    // pre-increment ++a
    // post-increment a++

    int a = 5;
    int b = 5;

    cout << a << endl;
    cout << a++ << endl;
    cout << a << endl;

    cout << endl;

    cout << b << endl;
    --b;
    cout << b << endl;
    return 0;
}