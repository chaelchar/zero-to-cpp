#include <iostream>
using namespace std;
int main(){
    // disini kita belajar gimana cara input  nilai ke variabel deklrasi


    int a;
    // ini adalah deklrasasi (kita tidak tau nilainya)
    int b = 10;
    // ini adalah inisiasi (kita memberikan nilainya)
    cout << "nilai dari b -> " << b << endl;
    cout << "masukan nilai a: ";
    cin >> a;

    cout << "nilai dari a : ";
    cout << a << endl;

    return 0;   
}